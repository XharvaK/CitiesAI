# Copy this file to packaging/secrets.local.env (gitignored).
# Used only on your machine when running scripts/build-release.ps1.
#
# 1. Discord: Server Settings -> Integrations -> Webhooks -> New Webhook
# 2. Pick your beta-feedback channel, copy "Webhook URL"
# 3. Paste below, save, rebuild the installer

CITIESAI_DISCORD_WEBHOOK=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
